# Zen Claude Bridge — Configuration
#
# Copy this file to .env and fill in your values.
# Never commit .env to version control!

# Local gateway key — used by Claude Desktop / Claude Code Gateway to authenticate
CLAUDE_GATEWAY_KEY=sk-local-zen

# Your OpenCode Zen API key (required for upstream calls)
OPENCODE_ZEN_API_KEY=replace_me

# Upstream model name (default: deepseek-v4-flash-free)
DEEPSEEK_MODEL=deepseek-v4-flash-free

# Upstream chat completions URL (auto-constructed from proxy host/port if not set)
DEEPSEEK_UPSTREAM_URL=http://127.0.0.1:9000/v1/chat/completions

# DeepSeek proxy server settings (used by run-deepseek-proxy.bat)
DEEPSEEK_PROXY_HOST=127.0.0.1
DEEPSEEK_PROXY_PORT=9000

# Bridge listen address
BRIDGE_HOST=127.0.0.1

# Bridge listen port
BRIDGE_PORT=4000

# Request timeout in seconds (default 600 = 10 minutes)
REQUEST_TIMEOUT_SECONDS=600

# Show "[deepseek-cursor-proxy] Refreshed reasoning_content history." notice
# Set to "true" to make it visible for debugging; default "false" strips it
SHOW_DEEPSEEK_RECOVERY_NOTICE=false

# ---------------------------------------------------------------
# Optional Bridge Memory Compaction
# ---------------------------------------------------------------
# Enable server-side memory compaction for long sessions.
BRIDGE_CONTEXT_COMPACTION=false

# Start compacting when estimated request tokens exceed this.
BRIDGE_COMPACTION_TRIGGER_TOKENS=180000

# Hard target after compaction.
BRIDGE_COMPACTION_TARGET_TOKENS=120000

# Always keep this many recent messages raw.
BRIDGE_COMPACTION_KEEP_RECENT_MESSAGES=20

# Max characters for the generated memory summary.
BRIDGE_COMPACTION_MAX_SUMMARY_CHARS=20000

# Where local memory summaries are stored.
BRIDGE_MEMORY_DIR=.bridge-memory

# ---------------------------------------------------------------
# Optional DeepSeek Reasoning Recovery Tracking
# ---------------------------------------------------------------
# Track reasoning_content recovery events per session.
BRIDGE_REASONING_RECOVERY_TRACKING=true

# Number of consecutive recovery events before triggering safe mode (auto only).
BRIDGE_REASONING_RECOVERY_THRESHOLD=3

# Reasoning-safe compaction mode: off, auto, or always.
# - off: never activate
# - auto: activate after repeated recovery
# - always: always use reasoning-safe history normalization
BRIDGE_REASONING_SAFE_MODE=auto

# Recovery threshold for auto mode activation.
BRIDGE_REASONING_SAFE_MODE_RECOVERY_THRESHOLD=3

# Keep this many recent messages raw when reasoning-safe mode is active.
BRIDGE_REASONING_SAFE_KEEP_RECENT_MESSAGES=8
