# Zen Claude Bridge — Configuration
#
# Copy this file to .env and fill in your values.
# Never commit .env to version control!

# Local gateway key — used by Claude Desktop / Claude Code Gateway to authenticate
CLAUDE_GATEWAY_KEY=sk-local-zen

# Your OpenCode Zen API key (required for upstream calls)
OPENCODE_ZEN_API_KEY=replace_me

# Upstream model name (default: deepseek-v4-flash-free)
DEEPSEEK_MODEL=deepseek-v4-flash-free

# Upstream chat completions URL
DEEPSEEK_UPSTREAM_URL=http://127.0.0.1:9000/v1/chat/completions

# Bridge listen address
BRIDGE_HOST=127.0.0.1

# Bridge listen port
BRIDGE_PORT=4000

# Request timeout in seconds (default 600 = 10 minutes)
REQUEST_TIMEOUT_SECONDS=600
